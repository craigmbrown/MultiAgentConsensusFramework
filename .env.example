# Multi-Agent Consensus Framework - Environment Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# LLM API Keys (Required - use your own keys)
# =============================================================================

# OpenAI API Key
OPENAI_API_KEY=sk-your-openai-api-key-here

# Anthropic API Key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# XAI/Grok API Key (optional - for 2M token context)
XAI_API_KEY=xai-your-xai-api-key-here

# =============================================================================
# System Configuration
# =============================================================================

# Consensus settings
CONSENSUS_THRESHOLD=0.75
QUALITY_THRESHOLD=0.80
MAX_AGENTS=40

# Agent configuration
DEFAULT_AGENT_COUNT=40
AGENT_TIMEOUT_SECONDS=120
MAX_RETRIES=3

# =============================================================================
# Monitoring & Alerting
# =============================================================================

ENABLE_MONITORING=true
MONITORING_PORT=8090
ALERT_ENABLED=false

# Alert destinations (optional)
# WHATSAPP_RECIPIENT=your-phone-number
# EMAIL_RECIPIENT=your-email@example.com

# =============================================================================
# External Integrations (Optional)
# =============================================================================

# Text-to-Speech (ElevenLabs)
TTS_ENABLED=false
# ELEVENLABS_API_KEY=your-elevenlabs-key

# Nostr Integration (for agent identity)
NOSTR_ENABLED=false
# NOSTR_NSEC_HEX=your-nostr-private-key
# NOSTR_NPUB=your-nostr-public-key

# Nostr Relays
NOSTR_RELAYS=wss://relay.damus.io,wss://nos.lol,wss://relay.nostr.band

# =============================================================================
# Lightning Network (Optional - for agent economy)
# =============================================================================

LIGHTNING_ENABLED=false
MOCK_LIGHTNING=true

# Federation settings (if using Fedimint)
# FEDIMINT_DATA_DIR=~/.fedimint-client
# FEDIMINT_FEDERATION=your-federation-name

# =============================================================================
# Cost Optimization
# =============================================================================

# Enable cost tracking
COST_TRACKING_ENABLED=true

# Budget limits (in USD)
DAILY_COST_LIMIT=50.00
PER_SESSION_LIMIT=5.00

# Model routing preferences
PREFER_CACHED_RESPONSES=true
USE_TIERED_ROUTING=true

# =============================================================================
# Development Settings
# =============================================================================

# Environment
ENVIRONMENT=development
DEBUG_MODE=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Test mode (uses mock responses)
TEST_MODE=false
